datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// ─── Users ───────────────────────────────────────────────

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String
  password      String
  avatar        String?
  plan          String           @default("free")
  credits       Int              @default(5)
  planExpiresAt DateTime?
  createdAt     DateTime         @default(now())
  history       ReadingHistory[]
  favorites     UserFavorite[]
  sessions      ReadingSession[]
  conversations AIConversation[]
  preferences   UserPreferences?
  achievements  UserAchievement[]
}

model UserPreferences {
  id             String @id @default(cuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests      String @default("[]")
  readingGoal    String?
  preferredStyle String?
  theme          String @default("light")
}

// ─── Books ───────────────────────────────────────────────

model Book {
  id            String           @id @default(cuid())
  title         String
  author        String
  coverImage    String?
  category      String?
  description   String?
  score         Float?
  publishYear   Int?
  totalReaders  Int              @default(0)
  tagsJson      String?
  createdAt     DateTime         @default(now())
  summaries     BookSummary[]
  history       ReadingHistory[]
  favorites     UserFavorite[]
  sessions      ReadingSession[]
  conversations AIConversation[]
  scene         BookScene?
}

model BookSummary {
  id           String   @id @default(cuid())
  bookId       String
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  pagesJson    String
  themeJson    String
  chaptersJson String?
  contentType  String   @default("summary")
  readingTime  Int      @default(15)
  rating       Float?
  ratingCount  Int      @default(0)
  ratings      SummaryRating[]
  generatedAt  DateTime @default(now())

  @@index([bookId])
}

model SummaryRating {
  id        String      @id @default(cuid())
  summaryId String
  summary   BookSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  userId    String
  score     Int
  feedback  String?
  createdAt DateTime    @default(now())

  @@unique([summaryId, userId])
  @@index([summaryId])
}

model BookScene {
  id          String   @id @default(cuid())
  bookId      String   @unique
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  sceneType   String
  sceneConfig String
  generatedAt DateTime @default(now())
}

// ─── Reading ─────────────────────────────────────────────

model ReadingHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId       String
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  lastReadPage Int      @default(0)
  readAt       DateTime @default(now())

  @@unique([userId, bookId])
  @@index([userId])
}

model ReadingSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId      String
  book        Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationMin Int       @default(0)

  @@index([userId])
  @@index([bookId])
}

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, bookId])
  @@index([userId])
}

// ─── AI Conversations ────────────────────────────────────

model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId    String
  book      Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  messages  AIMessage[]

  @@index([userId, bookId])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

// ─── Achievements ────────────────────────────────────────

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique
  name        String
  description String
  icon        String            @default("🏆")
  condition   String
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// ─── AI Usage Tracking ───────────────────────────────────

model AIUsageLog {
  id           String   @id @default(cuid())
  userId       String?
  bookId       String?
  action       String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
